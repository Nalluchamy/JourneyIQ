ENVIRONMENT=production
LOG_LEVEL=INFO

# Supabase PostgreSQL connection url (with connection pooling)
DATABASE_URL=postgresql+asyncpg://postgres.your-ref-id:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Application Secrets (Must be changed in production hosting dashboard)
SECRET_KEY=change-this-to-a-very-random-secret-key-for-production-security-hash
JWT_SECRET=change-this-to-a-very-random-jwt-signature-key-for-production-auth

# App URLs
FRONTEND_URL=https://journeyiq.vercel.app
BACKEND_URL=https://journeyiq-api.onrender.com

# Optional Redis connection
REDIS_URL=

# NVIDIA LLM API configuration
NVIDIA_API_KEY=

# Supabase Storage configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key
