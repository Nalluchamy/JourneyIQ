# JourneyIQ Testing Environment Variables
PORT=8000
ENVIRONMENT=testing
LOG_LEVEL=warning

# URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Security
SECRET_KEY=testing-secret-override-value-at-least-32-chars-long
JWT_SECRET=testing-jwt-override-value-at-least-32-chars-long

# Database (In-Memory SQLite)
DATABASE_URL=sqlite+aiosqlite:///:memory:
