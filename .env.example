# JourneyIQ Environment Variables Template

# Application Port
PORT=8000

# Backend URL (FastAPI)
BACKEND_URL=http://localhost:8000

# Frontend URL (Vite + React)
FRONTEND_URL=http://localhost:5173

# Uvicorn settings
ENVIRONMENT=development
LOG_LEVEL=info

# Security
SECRET_KEY=replace-with-a-very-secure-secret-key-for-production
JWT_SECRET=replace-with-a-very-secure-jwt-secret-for-production

# PostgreSQL Database Configuration
# NOTE: Using asyncpg driver for asynchronous SQLAlchemy connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/journeyiq
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=journeyiq
